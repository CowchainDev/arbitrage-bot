modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck-api-server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck-db"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck-api-zod"

[[workflows.workflow]]
name = "typecheck-api-server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server exec tsc --noEmit"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "typecheck-db"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/db exec tsc --noEmit"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "typecheck-api-zod"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-zod exec tsc --noEmit"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3001

[[ports]]
localPort = 23794
externalPort = 3000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.development]
KLINES_RELAY_URL = "https://arbitrage-bot-sjava06.replit.app/api/exchanges/relay-klines"

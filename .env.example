# ── PostgreSQL (provisioned automatically by Replit; copy values from Shell) ──
DATABASE_URL=postgresql://user:password@host:5432/dbname
PGHOST=
PGPORT=5432
PGUSER=
PGPASSWORD=
PGDATABASE=

# ── Clerk authentication ──────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# ── Session ───────────────────────────────────────────────────────────────────
# Any long random string (e.g. openssl rand -hex 32)
SESSION_SECRET=

# ── Bot authentication ────────────────────────────────────────────────────────
# Shared secret between the API server and the trading bot process
BOT_SECRET=

# ── Klines relay ──────────────────────────────────────────────────────────────
# URL of the deployed app's relay endpoint (used in development to proxy klines)
KLINES_RELAY_URL=https://your-app.replit.app/api/exchanges/relay-klines

# ── Server ────────────────────────────────────────────────────────────────────
# Assigned automatically by Replit; set manually for local development
PORT=3000

# ── Logging ───────────────────────────────────────────────────────────────────
# Options: trace | debug | info | warn | error | fatal  (default: info)
LOG_LEVEL=info
